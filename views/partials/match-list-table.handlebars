<table style="border-collapse: collapse; border: 3px solid #1D3557;" border="1" id="match-list">
  <thead>
    <tr class="main-table-header">

      {{#if groupedMatches}}
      <th colspan="6">{{currentDate}}</th>
      <th colspan="3">
        <form method="get" action="/"
          style="display: flex; justify-content: flex-end; align-items: center; height: 100%; margin: 0; padding: 0;">
          <button onclick="navigateDate(-1)" class="more-button input-change-arrow left">&#9668;</button>
          <input type="date" id="matchDate" class="gf-input" name="date" value="{{selectedDate}}" onchange="this.form.submit()" />
          <button onclick="navigateDate(1)" class="more-button input-change-arrow right">&#9658;</button>
        </form>
      </th>
      {{else}}
      <th colspan="3">Matches</th>   
      <th colspan="5">
        {{#if currentRound}}
        <div style="display: flex; align-items: center; justify-content: flex-end;">
          <button onclick="navigateRound(-1)" class="more-button input-change-arrow left">&#9668;</button>
          <select name="round" id="round-filter" class="gf-input" onchange="filterByRound(this.value)">
            <option value="">All Rounds</option>
            {{#each rounds}}
              <option value="{{this}}" {{#if (eq this ../currentRound)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
          <button onclick="navigateRound(1)" class="more-button input-change-arrow right">&#9658;</button>
        </div>
      </th>
      {{/if}}
      {{/if}}
    </tr>
  </thead>
  <tbody>
    {{#if groupedMatches}}
    {{#each groupedMatches}}
    <tr class="league-row">
      <td colspan="8" style="text-align:left; font-weight:bold; background:#457B9D;"><a
          href="/league?league={{this.league.id}}" style="color: white; text-decoration: none;">
          <img src="images/competitions/{{this.league.id}}.png" alt="{{this.league.name}}" width="24"
            style="vertical-align:middle; margin-right:6px;" />
          {{this.league.name}}</a>
      </td>
    </tr>

    {{#each this.matches}}
    <tr>
      <td class="match-list-date" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{formatTime fixture.date}}
      </td>

      <td class="match-list-team-name-td" id="{{teams.home.id}}"
        onclick="window.location.href='team?teamID={{teams.home.id}}'">
        {{teams.home.name}}
      </td>

      <td class="match-list-logo-td" onclick="window.location.href='team?teamID={{teams.home.id}}'">
        <img class="match-list-team-logo logo-picture" src="images/logos/{{teams.home.id}}.png"
          alt="{{teams.home.name}}" width="44px">
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.home}}
        {{#if statistics.[0].statistics.[16].value}}
        <span class="match-list-xg">({{statistics.[0].statistics.[16].value}})</span>
        {{/if}}
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        -
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.away}}
        {{#if statistics.[1].statistics.[16].value}}
        <span class="match-list-xg">({{statistics.[1].statistics.[16].value}})</span>
        {{/if}}
      </td>

      <td class="match-list-logo-td" onclick="window.location.href='team?teamID={{teams.away.id}}'">
        <img class="match-list-team-logo logo-picture" src="images/logos/{{teams.away.id}}.png"
          alt="{{teams.away.name}}" width="44px">
      </td>

      <td class="match-list-team-name-td" style="text-align:left" id="{{teams.away.id}}"
        onclick="window.location.href='team?teamID={{teams.away.id}}'">
        {{teams.away.name}}
      </td>
    </tr>
    {{/each}}
    {{/each}}
    {{else}}
    {{#each matches}}
    <tr data-round="{{this.league.round}}">
      <td class="match-list-date" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{formatDateOnly fixture.date}}<br>{{formatTime fixture.date}}
      </td>

      <td class="match-list-team-name-td" id="{{teams.home.id}}"
        onclick="window.location.href='team?teamID={{teams.home.id}}'">
        {{teams.home.name}}
      </td>

      <td class="match-list-logo-td" onclick="window.location.href='team?teamID={{teams.home.id}}'">
        <img class="match-list-team-logo" src="images/logos/{{teams.home.id}}.png" alt="{{teams.home.name}}"
          width="44px">
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.home}}
        {{#if statistics.[0].statistics.[16].value}}
        <span class="match-list-xg">({{statistics.[0].statistics.[16].value}})</span>
        {{/if}}
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        -
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.away}}
        {{#if statistics.[1].statistics.[16].value}}
        <span class="match-list-xg">({{statistics.[1].statistics.[16].value}})</span>
        {{/if}}
      </td>

      <td class="match-list-logo-td" onclick="window.location.href='team?teamID={{teams.away.id}}'">
        <img class="match-list-team-logo" src="images/logos/{{teams.away.id}}.png" alt="{{teams.away.name}}"
          width="44px">
      </td>

      <td class="match-list-team-name-td" style="text-align:left" id="{{teams.away.id}}"
        onclick="window.location.href='team?teamID={{teams.away.id}}'">
        {{teams.away.name}}
      </td>
    </tr>
    {{/each}}
    {{/if}}
  </tbody>
</table>

<script>
  function filterByRound(round) {
    const rows = document.querySelectorAll('#match-list tbody tr');
    rows.forEach(row => {
      if (!round || row.dataset.round === round) {
        row.style.display = '';
      } else {
        row.style.display = 'none';
      }
    });
  }

  function navigateRound(direction) {
    const select = document.getElementById('round-filter');
    const rounds = Array.from(select.options).slice(1).map(opt => opt.value); // skip "All Rounds"
    let currentValue = select.value;
    if (!currentValue) {
      // If "All Rounds" selected, go to first round
      select.value = rounds[0];
      filterByRound(rounds[0]);
      return;
    }
    const currentIndex = rounds.indexOf(currentValue);
    if (currentIndex === -1) return;
    const newIndex = currentIndex + direction;
    if (newIndex >= 0 && newIndex < rounds.length) {
      select.value = rounds[newIndex];
      filterByRound(rounds[newIndex]);
    }
  }

  function navigateDate(direction) {
    const input = document.getElementById('matchDate');
    const currentDate = new Date(input.value);
    currentDate.setDate(currentDate.getDate() + direction);
    const newDateStr = currentDate.toISOString().split('T')[0];
    input.value = newDateStr;
    input.form.submit();
  }

  filterByRound('{{currentRound}}');
</script>