<script src="controllers/match-list-table.js"></script>
<table class="gf-table" id="match-list">
  <thead>
    <tr class="main-table-header">

      {{#if groupedMatches}}
      <th colspan="6">Matches on Day</th>
      <th colspan="3">
        <form method="get" action="/"
          style="display: flex; justify-content: flex-end; align-items: center; height: 100%; margin: 0; padding: 0;">
          <button type="button" onclick="navigateDate(-1)" class="more-button input-change-arrow left">&#9668;</button>
          <input type="date" id="matchDate" class="gf-input" name="date" value="{{selectedDate}}"
            onchange="this.form.submit()" />
          <button type="button" onclick="navigateDate(1)" class="more-button input-change-arrow right">&#9658;</button>
        </form>
      </th>
      {{else}}
      {{#if matches}}
      <th colspan="4">Matches</th>
      <th colspan="5">
        {{#if currentRound}}
        <div style="display: flex; align-items: center; justify-content: flex-end;">
          <button type="button" onclick="navigateRound(-1)" class="more-button input-change-arrow left">&#9668;</button>
          <select name="round" id="round-filter" class="gf-input" onchange="filterByRound(this.value)">
            <option value="">All Rounds</option>
            {{#each rounds}}
            <option value="{{this}}" {{#if (eq this ../currentRound)}}selected{{/if}}>{{this}}</option>
            {{/each}}
          </select>
          <button type="button" onclick="navigateRound(1)" class="more-button input-change-arrow right">&#9658;</button>
        </div>
        {{/if}}
      </th>
      {{else}}
      <th colspan="6">Today's Matches</th>
      <th colspan="3">
        <form method="get" action="/"
          style="display: flex; justify-content: flex-end; align-items: center; height: 100%; margin: 0; padding: 0;">
          <button type="button" onclick="navigateDate(-1)" class="more-button input-change-arrow left">&#9668;</button>
          <input type="date" id="matchDate" class="gf-input" name="date" value="{{selectedDate}}"
            onchange="this.form.submit()" />
          <button type="button" onclick="navigateDate(1)" class="more-button input-change-arrow right">&#9658;</button>
        </form>
      </th>
      {{/if}}
      {{/if}}
    </tr>
  </thead>
  <tbody>
    {{#if groupedMatches}}
    {{#each groupedMatches}}
    <tr class="league-row">
      <td colspan="8" style="text-align:left; font-weight:bold; background:#457B9D;"><a
          href="/league?id={{this.league.id}}" style="color: white; text-decoration: none;">
          <img src="images/competitions/{{this.league.id}}.png" alt="{{this.league.name}}" width="24"
            style="vertical-align:middle; margin-right:6px;" />
          {{this.league.name}}</a>
      </td>
    </tr>

    {{#each this.matches}}
    <tr id="{{fixture.id}}">
      <td class="match-list-date" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{formatTime fixture.date}}<br />{{fixture.status.short}}
      </td>

      <td class="match-list-team-name-td" id="{{teams.home.id}}"
        onclick="window.location.href='team?ID={{teams.home.id}}'">
        {{teams.home.name}}
      </td>

      <td class="match-list-logo-td" onclick="window.location.href='team?ID={{teams.home.id}}'">
        <img class="match-list-team-logo logo-picture" src="images/logos/{{teams.home.id}}.png"
          alt="{{teams.home.name}}" title="{{teams.home.name}}" width="44px">
      </td>

      {{#if (eq fixture.status.short "PST")}}
      <td class="match-list-center-td" colspan="3" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        Postponed
      </td>
      {{else}}
      {{#if (eq fixture.status.short "CANC")}}
      <td class="match-list-center-td" colspan="3" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        Canceled
      </td>
      {{else}}
      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.home}}
        {{#if (expectedGoalsForTeam this teams.home.id)}}
        <span class="match-list-xg">({{expectedGoalsForTeam this teams.home.id}})</span>
        {{/if}}
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        -
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.away}}
        {{#if (expectedGoalsForTeam this teams.away.id)}}
        <span class="match-list-xg">({{expectedGoalsForTeam this teams.away.id}})</span>
        {{/if}}
      </td>
      {{/if}}
      {{/if}}

      <td class="match-list-logo-td" onclick="window.location.href='team?ID={{teams.away.id}}'">
        <img class="match-list-team-logo logo-picture" src="images/logos/{{teams.away.id}}.png"
          alt="{{teams.away.name}}" title="{{teams.away.name}}" width="44px">
      </td>

      <td class="match-list-team-name-td" style="text-align:left" id="{{teams.away.id}}"
        onclick="window.location.href='team?ID={{teams.away.id}}'">
        {{teams.away.name}}
      </td>
    </tr>
    {{/each}}
    {{else}}
    <tr>
      <td colspan="8" style="text-align:center; font-weight:bold; padding: 16px;">
        No matches to display for the day
      </td>
    </tr>
    {{/each}}
    {{else}}
    {{#each matches}}
    <tr id="{{fixture.id}}" data-round="{{this.league.round}}">
      <td class="match-list-date" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{formatDateOnly fixture.date}}<br>{{formatTime fixture.date}}
      </td>

      <td class="match-list-team-name-td" id="{{teams.home.id}}"
        onclick="window.location.href='team?ID={{teams.home.id}}'">
        {{teams.home.name}}
      </td>

      <td class="match-list-logo-td" onclick="window.location.href='team?ID={{teams.home.id}}'">
        <img class="match-list-team-logo" src="images/logos/{{teams.home.id}}.png" alt="{{teams.home.name}}"
          title="{{teams.home.name}}" width="44px">
      </td>

      {{#if (eq fixture.status.short "PST")}}
      <td class="match-list-center-td" colspan="3" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        Postponed
      </td>
      {{else}}
      {{#if (eq fixture.status.short "CANC")}}
      <td class="match-list-center-td" colspan="3" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        Canceled
      </td>
      {{else}}
      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.home}}
        {{#if (expectedGoalsForTeam this teams.home.id)}}
        <span class="match-list-xg">({{expectedGoalsForTeam this teams.home.id}})</span>
        {{/if}}
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        -
      </td>

      <td class="match-list-center-td" onclick="window.location.href='match?matchID={{this.fixture.id}}'">
        {{goals.away}}
        {{#if (expectedGoalsForTeam this teams.away.id)}}
        <span class="match-list-xg">({{expectedGoalsForTeam this teams.away.id}})</span>
        {{/if}}
      </td>
      {{/if}}
      {{/if}}

      <td class="match-list-logo-td" onclick="window.location.href='team?ID={{teams.away.id}}'">
        <img class="match-list-team-logo" src="images/logos/{{teams.away.id}}.png" alt="{{teams.away.name}}"
          title="{{teams.away.name}}" width="44px">
      </td>

      <td class="match-list-team-name-td" style="text-align:left" id="{{teams.away.id}}"
        onclick="window.location.href='team?ID={{teams.away.id}}'">
        {{teams.away.name}}
      </td>
      <td>
        <img class="match-list-competition-logo" src="images/competitions/{{league.id}}.png" alt="{{league.name}}" title="{{league.name}}" width="24px">
      </td>
    </tr>
    {{else}}
    <tr>
      <td colspan="8" style="text-align:center; font-weight:bold; padding: 16px;">
        No matches to display for the day
      </td>
    </tr>
    {{/each}}
    {{/if}}
  </tbody>
</table>

<script>
  filterByRound("{{currentRound}}");
</script>