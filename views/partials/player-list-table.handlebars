<table class="gf-table" id="player-list-table">
  <thead>
    <tr class="main-table-header">
      <th colspan="3" class="list-header">Player</th>
      <th width="50" class="list-header player-country">Team</th>
      <th class="list-header sortable" data-stat="apps">
        <span class="big-played">Apps</span>
        <span class="small-played">P</span>
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="goals">
        <img class="goal-icon" src="images/goal-icon.png" alt="Goals" title="Goals" width="20px"/>
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="npg">
        NPG
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="assists">
        <span class="big-played">Assists</span>
        <span class="small-played">A</span>
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable corners" data-stat="ga">
        GA
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="gap90">
        <span class="big-played">GA/90</span>
        <span class="small-played">GA90</span>
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="avRating">
        <span class="big-played">Rating</span>
        <span class="small-played">Rat.</span>
        <span class="sort-indicator"></span>
      </th>
      {{#if big}}
      <th class="list-header sortable" data-stat="minutes">
        Mins
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="pens">
        Pens
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="penaltiesMissed">
        Pens Miss
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="shotsTotal">
        Shots Total
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="shotsOn">
        Shots OnTarget
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="dribblesAttempts">
        Drib. Att
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="dribblesSucc">
        Drib. Succ
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="dribblesPast">
        Drib. Past
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="duelsTotal">
        Duels Total
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="duelsWon">
        Duels Won
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="keyPasses">
        Key Passes
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="foulsAgainst">
        Fouled.
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="foulsCommited">
        Fouls
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="blocks">
        Blocks
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="interceptions">
        Interc.
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="tackles">
        Tackles
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="yellowCards">
        <span class="yellow-card"></span>
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="redCards">
        <span class="red-card"></span>
        <span class="sort-indicator"></span>
      </th>
      <th class="list-header sortable" data-stat="age">
        Age
        <span class="sort-indicator"></span>
      </th>
      {{/if}}
    </tr>
  </thead>
  <tbody>
    {{#each players}}
    {{#if (lt @index 499)}}
    <tr {{#if (gt @index 99)}}style="display:none;" {{/if}}>
      <td id={{this.id}} style="text-align:center;padding:0; border-right: none;">
        <a href="/player?id={{this.id}}">
          <img class="player-picture" src="images/player-pictures/{{this.id}}.png" alt="{{this.name}}"
            onerror="this.onerror=null; this.src='images/player-pictures/default-player.png';" />
        </a>
      </td>
      <td id={{this.nation}} class="player-country">
        <img height="30" src="images/logos/{{this.nation}}.png" alt="{{this.nationName}}" title="{{this.nationName}}" />
      </td>
      <td class="sec-stats">
        <div class="player-name"><a href="/player?id={{this.id}}">{{this.name}}</a></div>
        <div class="player-position">{{this.position}}</div>
      </td>
      <td class="stat-td player-club" id={{this.club}}>
        <a href="/team?ID={{this.club}}"><img class="logo-picture" src="images/logos/{{this.club}}.png" alt="{{this.clubName}}" title="{{this.clubName}}" /></a>
      </td>
      <td class="stat-td" data-stat="apps">{{this.apps}}</td>
      <td class="stat-td" data-stat="goals">{{this.goals}}</td>
      <td class="stat-td" data-stat="npg">{{this.npg}}</td>
      <td class="stat-td" data-stat="assists">{{this.assists}}</td>
      <td class="stat-td corners" data-stat="ga">{{this.ga}}</td>
      <td class="stat-td" data-stat="gap90">{{this.gap90}}</td>
      <td class="stat-td {{ratingClass this.avRating}}" data-stat="avRating">{{this.avRating}}</td>
      {{#if ../big}}
      <td class="stat-td" data-stat="minutes">{{this.minutes}}</td>
      <td class="stat-td" data-stat="pens">{{this.penalties}}</td>
      <td class="stat-td" data-stat="penaltiesMissed">{{this.penaltiesMissed}}</td>
      <td class="stat-td" data-stat="shotsTotal">{{this.shotsTotal}}</td>
      <td class="stat-td" data-stat="shotsOn">{{this.shotsOn}}</td>
      <td class="stat-td" data-stat="dribblesAttempts">{{this.dribblesAttempts}}</td>
      <td class="stat-td" data-stat="dribblesSucc">{{this.dribblesSucc}}</td>
      <td class="stat-td" data-stat="dribblesPast">{{this.dribblesPast}}</td>
      <td class="stat-td" data-stat="duelsTotal">{{this.duelsTotal}}</td>
      <td class="stat-td" data-stat="duelsWon">{{this.duelsWon}}</td>
      <td class="stat-td" data-stat="keyPasses">{{this.keyPasses}}</td>
      <td class="stat-td" data-stat="foulsAgainst">{{this.foulsAgainst}}</td>
      <td class="stat-td" data-stat="foulsCommited">{{this.foulsCommited}}</td>
      <td class="stat-td" data-stat="blocks">{{this.blocks}}</td>
      <td class="stat-td" data-stat="interceptions">{{this.interceptions}}</td>
      <td class="stat-td" data-stat="tackles">{{this.tackles}}</td>
      <td class="stat-td" data-stat="yellowCards">{{this.yellowCards}}</td>
      <td class="stat-td" data-stat="redCards">{{this.redCards}}</td>
      <td class="stat-td" data-stat="age">{{this.age}}</td>
      {{/if}}
    </tr>
    {{/if}}
    {{/each}}
  </tbody>

</table>

<script>
  let allPlayers = [];
  try {
    let playersString = `{{{json players}}}`;
    if (playersString) {
      allPlayers = JSON.parse(playersString);
    }
  } catch (error) {
    console.error("Error parsing players data:", error);
    allPlayers = [];
  }

  let displayedPlayers = [...allPlayers];
</script>