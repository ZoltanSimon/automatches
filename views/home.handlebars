  <div class="rectangle" id="rectangle1">
    {{> rect-header title="Top Players" link="/players" leagues=leagues selectedLeagues=selectedPLeagues
    leaguepar="pleague" }}
    <div id="player-list" class="table-container">
      {{> player-list-table big=false}}
    </div>
    <span style="grid-column: 1/4; padding-left: 4px; padding-right: 4px">Top players across the selected leagues,
      ranked by goals, assists, ratings and non-penalty goals to highlight consistent attacking impact rather than
      isolated performances. Filter players by league by pressing the League button and extending the list of available leagues. <br/>Visit the <a href="./Players">Players page</a> for advanced filters and detailed per-match
      statistics.</span>
  </div>
  <div class="rectangle" id="rectangle5">
    <div class="team-page-header">
      <div class="rect-title">
        <div class="league-info">
          <a href="./league?id=1">
            <img src="./images/competitions/1.png" width="100" height="100" alt="World Cup">
            <h2>World Cup</h2>
          </a>
          
        </div>
      </div>
    </div>
    <div class="world-cup-content">
      {{#if knockoutRounds.length}}
      <div id="knockout-bracket-wrapper">
        {{> knockout-bracket knockoutRounds=knockoutRounds }}
      </div>
      {{else}}
      {{/if}}
    </div>
    <span style="grid-column: 1/4; padding-left: 4px; padding-right: 4px">FIFA World Cup knockout bracket showing all remaining matches, qualified teams, and current scorelines.</span>
  </div>

  <div class="rectangle" id="rectangle2">
    {{> rect-header title="Top Teams" link="/top-teams" leaguepar="tleague" leagues=leagues
    selectedLeagues=selectedTLeagues }}
    <div id="top-team-list" class="table-container">
      {{> team-list-table big=false}}
    </div>
    <span style="grid-column: 1/4; padding-left: 4px; padding-right: 4px">Top teams from the seven major European
      leagues, ranked by win percentage, recent form and key performance metrics to identify the strongest sides over
      time. Filter displayed teams by league by pressing the League button and extending the list of available leagues. <br/>Visit the <a href="./Teams">Top Teams page</a> for deeper team statistics or click a team to view the full
      squad.</span>
  </div>

  <div class="ads-container">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5722075030849203"
      crossorigin="anonymous"></script>
    <!-- ads-container -->
    <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-5722075030849203" data-ad-slot="5412168143"
      data-ad-format="auto" data-full-width-responsive="true"></ins>
    <script>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
</div>