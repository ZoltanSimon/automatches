<html lang="en">

<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-CJMS2M65FH"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-CJMS2M65FH');
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap"
    rel="stylesheet"
  >

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{{title}}</title>
  <meta name="description" content="{{description}}">
  <meta name="robots" content="index, follow">

  <link rel="icon" href="favicon.ico" type="image/x-icon" />
  <link rel="stylesheet" href="css/header.css" />
  <link rel="stylesheet" href="css/style.css" />

  <script async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5722075030849203"
    crossorigin="anonymous">
  </script>
</head>

<body>
  <header>
    <div class="logo-title">
      <a href="/"><img src="/images/logo.png" alt="Generation Football Logo" /></a>
      <a href="/"><h1>generationFOOTBALL</h1></a>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
    </div>
    <div class="header-league-search-wrapper">
      {{> league-search leagues=headerLeagues}}
    </div>
    <nav id="mainNav">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/players">Players</a></li>
        <li><a href="/top-teams">Teams</a></li>
        <li><a href="/starting11">Starting 11</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>
  </header>
  <script>
    (function () {
      var btn = document.getElementById('navToggle');
      var nav = document.getElementById('mainNav');
      if (btn && nav) {
        btn.addEventListener('click', function () {
          var open = nav.classList.toggle('nav-open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          btn.classList.toggle('nav-toggle--open', open);
        });
      }

      var searchBlocks = document.querySelectorAll('.js-league-search');
      if (searchBlocks.length === 0) {
        return;
      }

      var closeAllSearches = function () {
        searchBlocks.forEach(function (search) {
          var trigger = search.querySelector('.league-search-trigger');
          var dropdown = search.querySelector('.league-search-dropdown');
          if (!trigger || !dropdown) return;
          dropdown.hidden = true;
          trigger.setAttribute('aria-expanded', 'false');
          search.classList.remove('open');
        });
      };

      searchBlocks.forEach(function (search) {
        var trigger = search.querySelector('.league-search-trigger');
        var dropdown = search.querySelector('.league-search-dropdown');
        var input = search.querySelector('.league-search-input');
        var items = Array.prototype.slice.call(search.querySelectorAll('.league-search-item'));
        var emptyState = search.querySelector('.league-search-empty');

        if (!trigger || !dropdown || !input) {
          return;
        }

        trigger.addEventListener('click', function () {
          var isOpen = !dropdown.hidden;
          closeAllSearches();

          if (!isOpen) {
            dropdown.hidden = false;
            search.classList.add('open');
            trigger.setAttribute('aria-expanded', 'true');
            input.focus();
          }
        });

        input.addEventListener('input', function () {
          var query = input.value.trim().toLowerCase();
          var visibleCount = 0;

          items.forEach(function (item) {
            var nameElement = item.querySelector('.league-search-name');
            var leagueName = (nameElement ? nameElement.textContent : '').toLowerCase();
            var show = leagueName.indexOf(query) !== -1;
            item.hidden = !show;
            if (show) visibleCount += 1;
          });

          if (emptyState) {
            emptyState.hidden = visibleCount !== 0;
          }
        });

        search.addEventListener('keydown', function (event) {
          if (event.key === 'Escape') {
            closeAllSearches();
            trigger.focus();
          }
        });

        dropdown.addEventListener('click', function (event) {
          if (event.target.closest('.league-search-link')) {
            closeAllSearches();
          }
        });
      });

      document.addEventListener('click', function (event) {
        var clickedInsideAnySearch = Array.prototype.some.call(searchBlocks, function (search) {
          return search.contains(event.target);
        });

        if (!clickedInsideAnySearch) {
          closeAllSearches();
        }
      });
    })();
  </script>
  <main>
    {{{body}}}
  </main>
  <footer>
    <p>&copy; 2026 generationFOOTBALL - <a style="color: white" href="./privacy-policy">Privacy Policy</a></p>
  </footer>
</body>

</html>