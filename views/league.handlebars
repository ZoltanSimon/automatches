<script type="module" src="./../controllers/league.js"></script>
<style>
  .team-page-header {
    padding: 1rem 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .league {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .league img {
    width: 100px;
    height: 100px;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.4));
    flex-shrink: 0;
  }

  .league h2 {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: #f0f4f8;
    margin: 0;
    line-height: 1;
    text-transform: uppercase;
  }
</style>

<div class="container">
  <div class="team-page-header">
    <div class="league">
      <img src="images/competitions/{{leagueID}}.png" alt="{{leagueName}}">
      <h2>{{leagueName}}</h2>
    </div>
  </div>
  <div class="rectangle" id="rectangle4">
    <h2>Standings</h2>
    <div id="standings" class="table-container large">
      {{> standings }}
    </div>
  </div>

  <div class="rectangle" id="rectangle3">
    <span hidden id="league-name"></span>
    <span hidden id="league-id"></span>
    <span hidden id="round-no"></span>
    <div id="fixtures-info" class="table-container"></div>
    {{> match-list-table}}
  </div>
  <div class="rectangle" id="rectangle1">
    <h2>Top Players</h2>
    <div id="player-list" class="table-container">
      {{> player-list-table big=false}}
    </div>
  </div>

</div>