<script type="module" src="./../controllers/team.js"></script>

<div class="container">
    <div class="team-page-header">
        <div class="team">
            <img src="images/logos/{{thisTeam.ID}}.png" alt="{{thisTeam.Name}}">
            <div>{{thisTeam.name}}</div>
        </div>
        <div class="team-info">
            {{#each teamStats.[0].leagues}}
            <div onclick="window.location.href='/league?ID={{this.id}}'" style="cursor: pointer; display: flex; align-items: center; gap: 5px;">
                <img src="images/competitions/{{this.id}}.png" class="logo-picture" />
                <span>{{this.name}}</span>
            </div>
            {{/each}}

        </div>
        <div class="stat team-stats">
            <span>{{teamStats.[0].wins}}W {{teamStats.[0].draws}}D {{teamStats.[0].losses}}L<br/></span>
            <span class="pts value">{{percentage teamStats.[0].wins teamStats.[0].played}}% win<br/></span>
            <span class="per-game pts-per">{{teamStats.[0].perGame.points}} pts/game</span>
        </div>
        <div class="stat">
            <div class="label">Goals</div>
            <div class="value">{{teamStats.[0].total.goals}} - {{teamStats.[0].total.goalsAgainst}}</div>
            <div class="per-game">{{teamStats.[0].perGame.goals}} - {{teamStats.[0].perGame.goalsAgainst}}/game</div>
        </div>

        <div class="stat">
            <div class="label">xG</div>
            <div class="value">{{teamStats.[0].total.xG}} - {{teamStats.[0].total.xGA}}</div>
            <div class="per-game">{{teamStats.[0].perGame.xG}} - {{teamStats.[0].perGame.xGA}}/game</div>
        </div>

        <div class="stat">
            <div class="label">Corners</div>
            <div class="value">{{teamStats.[0].total.corners}} - {{teamStats.[0].total.cornersAgainst}}</div>
            <div class="per-game">{{teamStats.[0].perGame.corners}} - {{teamStats.[0].perGame.cornersAgainst}}/game</div>
        </div>

        <div class="stat">
            <div class="label">Shots on Goal</div>
            <div class="value">{{teamStats.[0].total.shotsOnGoal}} - {{teamStats.[0].total.shotsOnGoalAgainst}}</div>
            <div class="per-game">{{teamStats.[0].perGame.shotsOnGoal}} - {{teamStats.[0].perGame.shotsOnGoalAgainst}}/game</div>
        </div>
    </div>
    <div class="rectangle">
        <span hidden id="league-name"></span>
        <span hidden id="league-id"></span>
        <span hidden id="round-no"></span>
        <div id="fixtures-info" class="table-container">
            {{> match-list-table}}
        </div>
    </div>
    <div class="rectangle" style="padding: 8px;">
        <span>{{thisTeam.name}} is a football club which featured in the following competitions this season: {{#each teamStats.[0].leagues}} {{this.name}},
            {{/each}} having {{teamStats.[0].wins}} wins, {{teamStats.[0].draws}} draws, and {{teamStats.[0].losses}} losses. They've scored a total of {{teamStats.[0].total.goals}}, from {{teamStats.[0].total.xG}} expected goals, conceding {{teamStats.[0].total.goalsAgainst}} goals from {{teamStats.[0].total.xGA}} expected goals. <br/><br/>
        If you are interested in the featured competitions, click on the competition icons next to the team's logo and name. You can also click on the matches to see more details about them, or on the players to see their respective pages.   </span>
    </div>
    <div class="rectangle">
        <h2>Top Players</h2>
        <div id="player-list" class="table-container">
            {{> player-list-table big=false}}
        </div>
    </div>
</div>